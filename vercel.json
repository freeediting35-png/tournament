{
    "version": 2,
    "framework": "vite",
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/backend/server.js"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ],
    "installCommand": "npm install",
    "buildCommand": "npm run build"
}
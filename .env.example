# ── Firebase (Frontend) ────────────────────────────────────
# Get these from Firebase Console → Project Settings → Your Apps
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_FIREBASE_VAPID_KEY=your_vapid_key_from_cloud_messaging_settings

# ── Backend URL ────────────────────────────────────────────
VITE_BACKEND_URL=http://localhost:3001

# ── Backend (Node.js) ──────────────────────────────────────
# Fampay credentials (get from Fampay merchant dashboard)
FAMPAY_API_KEY=your_fampay_api_key
FAMPAY_MERCHANT_ID=your_fampay_merchant_id
FAMPAY_ACCOUNT_ID=your_fampay_account_id

# Admin credentials (CHANGE THESE IN PRODUCTION)
ADMIN_USERNAME=blazefire_admin
ADMIN_PASSWORD=BF@Secure2025!
ADMIN_JWT_SECRET=your_long_random_32_char_jwt_secret_key_here

# URLs
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3001
PORT=3001
